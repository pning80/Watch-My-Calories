# Backend Environment Configuration

# 1. Gemini API Key
# Provide your Google Gemini API Key below. Do not enclose it in quotes.
GEMINI_API_KEY=

# 2. Gemini Model Name
# This defines the default model for generating the calorie estimation.
# Example valid Gemini models currently available for generateContent:
#
# - gemini-2.5-flash (Gemini 2.5 Flash)
# - gemini-2.5-pro (Gemini 2.5 Pro)
# - gemini-2.0-flash (Gemini 2.0 Flash)
# - gemini-2.0-flash-001 (Gemini 2.0 Flash 001)
# - gemini-2.0-flash-exp-image-generation (Gemini 2.0 Flash (Image Generation) Experimental)
# - gemini-2.0-flash-lite (Gemini 2.0 Flash-Lite)
# - gemini-2.5-flash-lite (Gemini 2.5 Flash-Lite)
# - gemini-2.5-flash-preview-tts (Gemini 2.5 Flash Preview TTS)
# - gemini-3-pro-preview (Gemini 3 Pro Preview)
# - gemini-3-flash-preview (Gemini 3 Flash Preview)
# - gemini-3.1-pro-preview (Gemini 3.1 Pro Preview)
# - gemini-3.1-flash-lite (Gemini 3.1 Flash-Lite)
#
GEMINI_MODEL_NAME=gemini-3.1-flash-lite

# 3. Client Verification Key (dev only — disabled in production)
# Used for legacy x-backend-key auth on simulators and dev builds.
# Not needed for production deployments (App Attest is required).
APP_BACKEND_API_KEY=WatchMyCalories_Secret_Key_Change_Me

# 4. Apple App Attest Configuration
# Your Apple Developer Team ID (10-character alphanumeric string).
# Required for App Attest verification.
APPLE_TEAM_ID=

# 4b. Play Integrity (Android attestation)
# Your GCP project NUMBER (not the project ID) — the audience for Play Integrity
# verdicts. Required by deploy.sh.
PLAY_INTEGRITY_PROJECT_NUMBER=

# 5. App Attest HMAC Secret
# In production, the HMAC secret is auto-generated by deploy.sh and stored in
# Secret Manager (the backend only reads it). You do NOT need to set it here.
# For local development without Secret Manager, you can override it:
# ATTEST_HMAC_SECRET=<any-hex-string>

# 6. Rate Limiting (optional — defaults shown)
# RATE_LIMIT_GLOBAL_WINDOW_MS=900000
# RATE_LIMIT_GLOBAL_MAX=100
# RATE_LIMIT_GEMINI_WINDOW_MS=900000
# RATE_LIMIT_GEMINI_MAX=100
# RATE_LIMIT_ATTEST_WINDOW_MS=900000
# RATE_LIMIT_ATTEST_MAX=30
# RATE_LIMIT_LEGACY_KEY_WINDOW_MS=900000
# RATE_LIMIT_LEGACY_KEY_MAX=15

# 7. Firestore Collection Name
# ATTESTED_KEYS_COLLECTION is set automatically by deploy.sh based on the
# prod/dev argument (prod → "attestedKeys-prod", dev → "attestedKeys-dev").
# You do NOT need to set it in your .env file.
