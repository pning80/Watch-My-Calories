{
    "name": "watchmycalories-backend",
    "version": "1.1.0",
    "description": "Backend relay for Gemini API",
    "main": "dist/server.js",
    "scripts": {
        "build": "tsc",
        "start": "node dist/server.js",
        "dev": "tsx --watch server.ts",
        "test": "npm run build && tsx --test test/*.test.ts",
        "test:smoke": "TARGET_ENV=dev tsx --test test/deployment/*.test.ts",
        "test:smoke:prod": "TARGET_ENV=prod tsx --test test/deployment/*.test.ts"
    },
    "dependencies": {
        "@google-cloud/firestore": "^7.11.0",
        "@google-cloud/secret-manager": "^5.6.0",
        "cbor-x": "^1.6.0",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.19.2",
        "express-rate-limit": "^8.3.0",
        "pino": "^10.3.1"
    },
    "devDependencies": {
        "@peculiar/webcrypto": "^1.5.0",
        "@peculiar/x509": "^1.12.0",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/node": "^25.5.0",
        "@types/supertest": "^7.2.0",
        "supertest": "^7.0.0",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3"
    },
    "engines": {
        "node": ">=20.0.0"
    }
}
