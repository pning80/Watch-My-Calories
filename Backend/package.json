{
    "name": "watchmycalories-backend",
    "version": "1.1.0",
    "description": "Backend relay for Gemini API",
    "main": "server.js",
    "scripts": {
        "start": "node server.js",
        "dev": "node --watch server.js",
        "test": "node --test test/*.test.js",
        "test:smoke": "TARGET_ENV=dev node --test test/deployment/*.test.js",
        "test:smoke:prod": "TARGET_ENV=prod node --test test/deployment/*.test.js"
    },
    "dependencies": {
        "@google-cloud/firestore": "^7.11.0",
        "@google-cloud/secret-manager": "^5.6.0",
        "cbor-x": "^1.6.0",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.19.2",
        "express-rate-limit": "^8.3.0"
    },
    "devDependencies": {
        "@peculiar/webcrypto": "^1.5.0",
        "@peculiar/x509": "^1.12.0",
        "supertest": "^7.0.0"
    },
    "engines": {
        "node": ">=20.0.0"
    }
}
