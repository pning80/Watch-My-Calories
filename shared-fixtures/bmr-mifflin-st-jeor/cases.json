{
  "formula": {
    "description": "Mifflin-St Jeor BMR + activity multiplier (TDEE).",
    "bmr": "10*weightKg + 6.25*heightCm - 5*age + (gender == MALE ? +5 : -161)",
    "tdee": "round(bmr * activityMultiplier)",
    "rounding": "Half rounds away from zero (kotlin.math.roundToInt, Swift Double.rounded()). Tolerance: ±1 kcal."
  },
  "activityMultipliers": {
    "SEDENTARY": 1.2,
    "LIGHTLY_ACTIVE": 1.375,
    "MODERATELY_ACTIVE": 1.55,
    "VERY_ACTIVE": 1.725
  },
  "genderOffsets": {
    "MALE": 5,
    "FEMALE": -161,
    "OTHER": -161
  },
  "cases": [
